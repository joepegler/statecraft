{
  "name": "statecraft",
  "private": true,
  "description": "Composable Ethereum integration-test scenarios for Vitest and viem (monorepo).",
  "type": "module",
  "packageManager": "bun@1.2.4",
  "keywords": [
    "ethereum",
    "evm",
    "vitest",
    "viem",
    "anvil",
    "testing",
    "statecraft",
    "web3"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joepegler/statecraft.git"
  },
  "bugs": {
    "url": "https://github.com/joepegler/statecraft/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces build",
    "docs:build": "vocs build",
    "docs:dev": "vocs dev",
    "docs:preview": "vocs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --workspaces typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vocs": "1.0.12",
    "zile": "^0.0.22"
  }
}
