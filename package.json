{
  "name": "statecraft",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.4",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces build",
    "docs:build": "vocs build",
    "docs:dev": "vocs dev",
    "docs:preview": "vocs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --workspaces typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vocs": "^1.0.0-next.20250228T022228",
    "zile": "^0.0.22"
  }
}
